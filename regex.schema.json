{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/yoeunes/regex-parser/main/regex.schema.json",
  "title": "RegexParser Lint Configuration",
  "description": "Configuration schema for RegexParser CLI lint defaults (regex.json or regex.dist.json).",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "description": "A single string or a list of strings.",
      "anyOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      ]
    },
    "optimizationOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "digits": {
          "type": "boolean",
          "description": "Optimize digit character classes like [0-9] to \\d.",
          "default": true
        },
        "word": {
          "type": "boolean",
          "description": "Optimize word character classes like [A-Za-z0-9_] to \\w.",
          "default": true
        },
        "ranges": {
          "type": "boolean",
          "description": "Optimize consecutive character ranges.",
          "default": true
        },
        "canonicalizeCharClasses": {
          "type": "boolean",
          "description": "Canonicalize character classes (sort ranges, remove duplicates).",
          "default": true
        },
        "possessive": {
          "type": "boolean",
          "description": "Suggest possessive quantifiers (*+, ++, {m,n}+) to prevent ReDoS.",
          "default": false
        },
        "factorize": {
          "type": "boolean",
          "description": "Factorize common prefixes/suffixes in alternations.",
          "default": false
        },
        "minQuantifierCount": {
          "type": "integer",
          "description": "Minimum quantifier count required to suggest optimizations (min: 2).",
          "minimum": 2,
          "default": 4
        },
        "verifyWithAutomata": {
          "type": "boolean",
          "description": "Verify optimization suggestions with the automata solver when possible.",
          "default": true
        }
      }
    },
    "checksRedos": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ReDoS vulnerability analysis. Disabled by default for performance; enable explicitly when needed.",
          "default": false
        },
        "mode": {
          "type": "string",
          "description": "ReDoS analysis mode.",
          "enum": ["off", "theoretical", "confirmed"],
          "enumDescriptions": [
            "Disable ReDoS analysis.",
            "Report theoretical ReDoS risks.",
            "Only report confirmed ReDoS risks."
          ],
          "x-intellij-enum-metadata": [
            {
              "value": "off",
              "description": "Disable ReDoS analysis."
            },
            {
              "value": "theoretical",
              "description": "Report theoretical ReDoS risks."
            },
            {
              "value": "confirmed",
              "description": "Only report confirmed ReDoS risks."
            }
          ],
          "default": "theoretical"
        },
        "threshold": {
          "type": "string",
          "description": "Minimum severity threshold for reporting ReDoS issues.",
          "enum": ["low", "medium", "high", "critical"],
          "enumDescriptions": [
            "Report low and higher.",
            "Report medium and higher.",
            "Report high and higher.",
            "Report only critical."
          ],
          "x-intellij-enum-metadata": [
            {
              "value": "low",
              "description": "Report low and higher."
            },
            {
              "value": "medium",
              "description": "Report medium and higher."
            },
            {
              "value": "high",
              "description": "Report high and higher."
            },
            {
              "value": "critical",
              "description": "Report only critical."
            }
          ],
          "default": "high"
        },
        "noJit": {
          "type": "boolean",
          "description": "Disable PHP JIT when running ReDoS analysis (prevents false positives).",
          "default": false
        }
      }
    },
    "checksOptimizations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable regex optimization suggestions.",
          "default": true
        },
        "minSavings": {
          "type": "integer",
          "description": "Minimum character savings threshold to report optimization suggestions.",
          "minimum": 1,
          "default": 1
        },
        "options": {
          "$ref": "#/$defs/optimizationOptions"
        }
      }
    },
    "checksLint": {
      "type": "object",
      "description": "Lint check settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable lint checks for regex anti-patterns and style issues.",
          "default": true
        },
        "rules": {
          "type": "object",
          "description": "Enable or disable specific lint rules. All rules are enabled by default except unicode.shorthandWithoutU.",
          "additionalProperties": false,
          "properties": {
            "unicode.shorthandWithoutU": {
              "type": "boolean",
              "description": "Warn when \\w, \\d, \\s are used without /u flag (ASCII-only matching).",
              "default": false
            },
            "unicode.propertyWithoutU": {
              "type": "boolean",
              "description": "Error when \\p{...} Unicode properties are used without /u flag.",
              "default": true
            },
            "unicode.bracedHexWithoutU": {
              "type": "boolean",
              "description": "Error when \\x{...} escapes with code points > 0xFF are used without /u flag.",
              "default": true
            },
            "flag.useless.i": {
              "type": "boolean",
              "description": "Warn when /i flag is used but pattern has no case-sensitive characters.",
              "default": true
            },
            "flag.useless.m": {
              "type": "boolean",
              "description": "Warn when /m flag is used but pattern has no anchors.",
              "default": true
            },
            "flag.useless.s": {
              "type": "boolean",
              "description": "Warn when /s flag is used but pattern has no dots.",
              "default": true
            },
            "flag.redundant": {
              "type": "boolean",
              "description": "Warn about redundant flag modifiers.",
              "default": true
            },
            "flag.override": {
              "type": "boolean",
              "description": "Warn when inline flags override outer flags.",
              "default": true
            },
            "charclass.redundant": {
              "type": "boolean",
              "description": "Warn about redundant character classes like [a].",
              "default": true
            },
            "charclass.suspiciousRange": {
              "type": "boolean",
              "description": "Warn about suspicious character ranges like [A-z].",
              "default": true
            },
            "charclass.suspiciousPipe": {
              "type": "boolean",
              "description": "Warn about literal pipe in character class (likely meant alternation).",
              "default": true
            },
            "charclass.duplicateChars": {
              "type": "boolean",
              "description": "Warn about duplicate elements in character classes.",
              "default": true
            },
            "charclass.backrefAsOctal": {
              "type": "boolean",
              "description": "Warn when \\1-\\9 in character class is octal, not a backreference.",
              "default": true
            },
            "charclass.literalMetachar": {
              "type": "boolean",
              "description": "Warn about unescaped metacharacters in character classes.",
              "default": true
            },
            "alternation.empty": {
              "type": "boolean",
              "description": "Warn about empty alternatives in alternations.",
              "default": true
            },
            "alternation.duplicateDisjunction": {
              "type": "boolean",
              "description": "Warn about duplicate branches in alternations.",
              "default": true
            },
            "alternation.overlap": {
              "type": "boolean",
              "description": "Warn about overlapping alternatives that may cause backtracking.",
              "default": true
            },
            "alternation.dotNewline": {
              "type": "boolean",
              "description": "Warn about (.|\n) anti-pattern for matching any character.",
              "default": true
            },
            "quantifier.useless": {
              "type": "boolean",
              "description": "Warn about useless quantifiers like {1}.",
              "default": true
            },
            "quantifier.zero": {
              "type": "boolean",
              "description": "Warn about quantifiers that always match zero times.",
              "default": true
            },
            "quantifier.nested": {
              "type": "boolean",
              "description": "Warn about nested quantifiers that may cause catastrophic backtracking.",
              "default": true
            },
            "quantifier.concatenation": {
              "type": "boolean",
              "description": "Warn about concatenated quantifiers that can be optimized.",
              "default": true
            },
            "group.redundant": {
              "type": "boolean",
              "description": "Warn about redundant non-capturing groups.",
              "default": true
            },
            "group.quantifiedCapture": {
              "type": "boolean",
              "description": "Warn about quantified capturing groups where only last match is retained.",
              "default": true
            },
            "anchor.impossible.start": {
              "type": "boolean",
              "description": "Warn about impossible start anchor positions.",
              "default": true
            },
            "anchor.impossible.end": {
              "type": "boolean",
              "description": "Warn about impossible end anchor positions.",
              "default": true
            },
            "backref.undefined": {
              "type": "boolean",
              "description": "Warn about references to undefined groups.",
              "default": true
            },
            "backref.useless": {
              "type": "boolean",
              "description": "Warn about useless backreferences.",
              "default": true
            },
            "dotstar.nested": {
              "type": "boolean",
              "description": "Warn about nested dot-star patterns that cause severe backtracking.",
              "default": true
            },
            "escape.suspicious": {
              "type": "boolean",
              "description": "Warn about suspicious escape sequences.",
              "default": true
            },
            "range.useless": {
              "type": "boolean",
              "description": "Warn about useless character ranges.",
              "default": true
            },
            "overlap.charset": {
              "type": "boolean",
              "description": "Warn about overlapping character sets in alternations.",
              "default": true
            }
          }
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor integration.",
      "format": "uri-reference",
      "examples": ["./regex.schema.json"]
    },
    "$id": {
      "type": "string",
      "description": "Schema identifier (usually a URL).",
      "format": "uri-reference"
    },
    "paths": {
      "allOf": [
        {
          "$ref": "#/$defs/stringList"
        }
      ],
      "description": "Directories or files to scan for regex patterns. Omit to scan the working directory.",
      "examples": ["src", ["src", "tests"]]
    },
    "exclude": {
      "allOf": [
        {
          "$ref": "#/$defs/stringList"
        }
      ],
      "description": "Paths to exclude from scanning. Omit to use the CLI default (vendor).",
      "examples": ["vendor", ["vendor", "tests", "Fixtures"]]
    },
    "jobs": {
      "type": "integer",
      "description": "Number of parallel workers. Omit to auto-detect based on CPU cores.",
      "minimum": 1,
      "examples": [4]
    },
    "minSavings": {
      "type": "integer",
      "description": "Deprecated. Use checks.optimizations.minSavings.",
      "minimum": 1,
      "default": 1,
      "examples": [2],
      "deprecated": true
    },
    "format": {
      "type": "string",
      "description": "Output format for lint results.",
      "enum": ["console", "json", "github", "checkstyle", "junit"],
      "enumDescriptions": [
        "Human-friendly console output.",
        "Machine-readable JSON report.",
        "GitHub Actions annotations format.",
        "Checkstyle XML report.",
        "JUnit XML report."
      ],
      "x-intellij-enum-metadata": [
        {
          "value": "console",
          "description": "Human-friendly console output."
        },
        {
          "value": "json",
          "description": "Machine-readable JSON report."
        },
        {
          "value": "github",
          "description": "GitHub Actions annotations format."
        },
        {
          "value": "checkstyle",
          "description": "Checkstyle XML report."
        },
        {
          "value": "junit",
          "description": "JUnit XML report."
        }
      ],
      "default": "console"
    },
    "ide": {
      "description": "IDE name or custom URL template for clickable file links. Use placeholders like %f, %l, %c, or %relFile%.",
      "default": "",
      "oneOf": [
        {
          "const": "",
          "description": "Disable clickable links."
        },
        {
          "const": "phpstorm",
          "description": "Use phpstorm://open?file=%f&line=%l"
        },
        {
          "const": "vscode",
          "description": "Use vscode://file/%f:%l"
        },
        {
          "const": "textmate",
          "description": "Use txmt://open?url=file://%f&line=%l"
        },
        {
          "const": "sublime",
          "description": "Use subl://open?url=file://%f&line=%l"
        },
        {
          "const": "emacs",
          "description": "Use emacs://open?url=file://%f&line=%l"
        },
        {
          "const": "atom",
          "description": "Use atom://core/open/file?filename=%f&line=%l"
        },
        {
          "const": "macvim",
          "description": "Use mvim://open?url=file://%f&line=%l"
        },
        {
          "type": "string",
          "minLength": 1,
          "pattern": ".*%(?:f|file%|relFile%|l|line%|c|column%).*",
          "description": "Custom URL template with placeholders."
        }
      ],
      "examples": ["phpstorm", "vscode", "vscode://file/%f:%l"]
    },
    "checks": {
      "type": "object",
      "description": "Enable or configure lint checks (preferred).",
      "additionalProperties": false,
      "properties": {
        "validation": {
          "type": "boolean",
          "description": "Enable regex syntax validation.",
          "default": true
        },
        "redos": {
          "description": "ReDoS analysis settings or toggle.",
          "anyOf": [
            {
              "type": "boolean",
              "description": "Enable or disable ReDoS analysis."
            },
            {
              "$ref": "#/$defs/checksRedos"
            }
          ]
        },
        "optimizations": {
          "description": "Optimization suggestion settings or toggle.",
          "anyOf": [
            {
              "type": "boolean",
              "description": "Enable or disable optimization suggestions."
            },
            {
              "$ref": "#/$defs/checksOptimizations"
            }
          ]
        },
        "lint": {
          "description": "Lint check settings or toggle.",
          "anyOf": [
            {
              "type": "boolean",
              "description": "Enable or disable lint checks."
            },
            {
              "$ref": "#/$defs/checksLint"
            }
          ]
        }
      }
    },
    "rules": {
      "type": "object",
      "description": "Deprecated. Use checks instead.",
      "additionalProperties": false,
      "deprecated": true,
      "properties": {
        "redos": {
          "type": "boolean",
          "description": "Enable ReDoS vulnerability analysis.",
          "default": false
        },
        "validation": {
          "type": "boolean",
          "description": "Enable regex syntax validation.",
          "default": true
        },
        "optimization": {
          "type": "boolean",
          "description": "Enable regex optimization suggestions.",
          "default": true
        }
      }
    },
    "redosMode": {
      "type": "string",
      "description": "Deprecated. Use checks.redos.mode.",
      "enum": ["off", "theoretical", "confirmed"],
      "enumDescriptions": [
        "Disable ReDoS analysis.",
        "Report theoretical ReDoS risks.",
        "Only report confirmed ReDoS risks."
      ],
      "x-intellij-enum-metadata": [
        {
          "value": "off",
          "description": "Disable ReDoS analysis."
        },
        {
          "value": "theoretical",
          "description": "Report theoretical ReDoS risks."
        },
        {
          "value": "confirmed",
          "description": "Only report confirmed ReDoS risks."
        }
      ],
      "default": "theoretical",
      "deprecated": true
    },
    "redosThreshold": {
      "type": "string",
      "description": "Deprecated. Use checks.redos.threshold.",
      "enum": ["low", "medium", "high", "critical"],
      "enumDescriptions": [
        "Report low and higher.",
        "Report medium and higher.",
        "Report high and higher.",
        "Report only critical."
      ],
      "x-intellij-enum-metadata": [
        {
          "value": "low",
          "description": "Report low and higher."
        },
        {
          "value": "medium",
          "description": "Report medium and higher."
        },
        {
          "value": "high",
          "description": "Report high and higher."
        },
        {
          "value": "critical",
          "description": "Report only critical."
        }
      ],
      "default": "high",
      "deprecated": true
    },
    "redosNoJit": {
      "type": "boolean",
      "description": "Deprecated. Use checks.redos.noJit.",
      "default": false,
      "deprecated": true
    },
    "optimizations": {
      "allOf": [
        {
          "$ref": "#/$defs/optimizationOptions"
        }
      ],
      "description": "Deprecated. Use checks.optimizations.options.",
      "deprecated": true
    }
  },
  "examples": [
    {
      "$schema": "./regex.schema.json",
      "paths": ["src"],
      "exclude": ["vendor", "tests"],
      "format": "console",
      "jobs": 4,
      "ide": "phpstorm",
      "checks": {
        "validation": true,
        "redos": {
          "mode": "theoretical",
          "threshold": "high"
        },
        "optimizations": {
          "minSavings": 2,
          "options": {
            "digits": true,
            "word": true,
            "ranges": true,
            "canonicalizeCharClasses": true,
            "possessive": false,
            "factorize": false,
            "minQuantifierCount": 4,
            "verifyWithAutomata": true
          }
        }
      }
    }
  ]
}
